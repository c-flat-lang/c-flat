---
source: bitbox/src/test.rs
expression: "snapshot_compiler(Target::X86_64Linux, DebugPass::VirtRegRewrite,\n\"../examples/fib.bitbox\", contents)"
---
.intel_syntax noprefix
.globl main
  # Defining Function fib
fib:
  push rbp
  mov rbp, rsp
  sub rsp, 32
  # -- args --
  # arg: n
  mov dword ptr [rbp-4], edi
  # arg: a
  mov dword ptr [rbp-8], esi
  # arg: b
  mov dword ptr [rbp-12], edx
fib_entry:
  # @assign s32 : tmp.0_v0, 0
  # lowering assign
  # lowering operand
  mov r10, 0
  mov dword ptr [rbp-16], r10d
  # @cmp s32 : tmp.1_v0, n_v0, tmp.0_v0
  # lowering cmp
  # lowering operand
  # lowering operand
  mov r10d, dword ptr [rbp-16]
  cmp dword ptr [rbp-4], r10d
  sete r10b
  movzx r11, r10b
  # @jumpif tmp.1_v0, %then.1
  # lowering jump if
  # lowering operand
  test r11, r11
  jnz fib_then_1
  # @jump %merge.3
  # lowering jump if
  jmp fib_merge_3
fib_then_1:
  # @ret s32 : a_v0
  # lowering return
  mov eax, dword ptr [rbp-8]
  jmp exit_fib
  # @jump %merge.3
  # lowering jump if
  jmp fib_merge_3
fib_merge_3:
  # @assign s32 : tmp.2_v0, 1
  # lowering assign
  # lowering operand
  mov r11, 1
  mov dword ptr [rbp-20], r11d
  # @sub s32 : tmp.3_v0, n_v0, tmp.2_v0
  # lowering sub
  # lowering operand
  # lowering operand
  mov r11d, dword ptr [rbp-4]
  sub r11d, dword ptr [rbp-20]
  # @add s32 : tmp.4_v0, a_v0, b_v0
  # lowering add
  # lowering operand
  # lowering operand
  mov r10d, dword ptr [rbp-8]
  add r10d, dword ptr [rbp-12]
  # @call s32 : tmp.5_v0 fib(tmp.3_v0, b_v0, tmp.4_v0)
  # lowering call
  # lowering operand
  mov dword ptr [rbp-24], r11d
  # lowering operand
  # lowering operand
  mov dword ptr [rbp-28], r10d
  mov edi, dword ptr [rbp-24]
  mov esi, dword ptr [rbp-12]
  mov edx, dword ptr [rbp-28]
  call fib
  mov r10, rax
  # @ret s32 : tmp.5_v0
  # lowering return
  mov eax, r10d
  jmp exit_fib
exit_fib:
  add rsp, 32
  mov rsp, rbp
  pop rbp
  ret
  # --- End of Function fib ---
  # Defining Function main
main:
  push rbp
  mov rbp, rsp
  sub rsp, 32
  # -- args --
main_entry:
  # @assign s32 : tmp.0_v0, 55
  # lowering assign
  # lowering operand
  mov r10, 55
  mov dword ptr [rbp-4], r10d
  # @assign s32 : tmp.1_v0, 0
  # lowering assign
  # lowering operand
  mov r10, 0
  mov dword ptr [rbp-8], r10d
  # @assign s32 : tmp.2_v0, 1
  # lowering assign
  # lowering operand
  mov r10, 1
  mov dword ptr [rbp-12], r10d
  # @call s32 : tmp.3_v0 fib(tmp.0_v0, tmp.1_v0, tmp.2_v0)
  # lowering call
  # lowering operand
  # lowering operand
  # lowering operand
  mov edi, dword ptr [rbp-4]
  mov esi, dword ptr [rbp-8]
  mov edx, dword ptr [rbp-12]
  call fib
  mov r10, rax
  # @assign s32 : value_v0, tmp.3_v0
  # lowering assign
  # lowering operand
  mov dword ptr [rbp-16], r10d
  # @call write_int(value_v0)
  # lowering call
  # lowering operand
  mov edi, dword ptr [rbp-16]
  call write_int
  # @assign s32 : tmp.4_v0, 10
  # lowering assign
  # lowering operand
  mov r10, 10
  mov dword ptr [rbp-20], r10d
  # @call write_char(tmp.4_v0)
  # lowering call
  # lowering operand
  mov edi, dword ptr [rbp-20]
  call write_char
  # @assign s32 : tmp.5_v0, 0
  # lowering assign
  # lowering operand
  mov r10, 0
  mov dword ptr [rbp-24], r10d
  # @ret s32 : tmp.5_v0
  # lowering return
  mov eax, dword ptr [rbp-24]
  jmp exit_main
exit_main:
  add rsp, 32
  mov rsp, rbp
  pop rbp
  ret
  # --- End of Function main ---
