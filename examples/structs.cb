extern C fn write_int(s32) void;
extern C fn write_char(u8) void;

type List struct {
  data: [2; s32],
}

fn init_list() List {
  let list: List = List { .data = [0; 2] };
  return list;
}

fn set_list(list: *List, index: s32, value: s32) void {
  list.data[index] = value;
}

pub fn main() s32 {
  let list: List = init_list();
  write_int(list.data[0]);
  write_char(10);
  set_list(&list, 0, 1);
  write_int(list.data[0]);
  write_char(10);
  return 0;
}
