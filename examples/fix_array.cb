extern C fn write_int(s32) void;
extern C fn write_char(u8) void;

pub fn main() s32 {
    let array: [2; s32] = [0; 2];
    let mut i = 0;
    while i < array.len {
        array[i] = i;
        i = i + 1;
    }

    i = 0

    while i < array.len {
        write_int(array[i]);
        write_char(10);
        i = i + 1;
    }
    return 0;
}
