extern C fn write_s32(s32) void;
extern C fn write_char(u8) void;

fn print_number(n: s32) void {
    write_s32(n);
    write_char('\n');
}

pub fn main() void {
    let a = 10;
    let b = 5;

    if a < b {
        print_number(1);
    } else if a > b {
        print_number(2);
    } else {
        print_number(3);
    }

    if true {
        if true {
            if true {
                print_number(4);
            }
        }
    }
}
