fn rule110(l: s32, c: s32, r: s32) s32 {
    let idx = l * 4 + c * 2 + r;
    let keys: [8; s32] = [0; 8];
    keys[1] = 1;
    keys[2] = 1;
    keys[3] = 1;
    keys[5] = 1;
    keys[6] = 1;
    return keys[idx]
}
// (fn is-alive (id)
//   (nth ' id))

pub fn main() s32 {
    write_int(rule110(0,0,0));
    write_char(10);
    write_int(rule110(0,0,1));
    write_char(10);
    write_int(rule110(0,1,0));
    write_char(10);
    write_int(rule110(0,1,1));
    write_char(10);
    write_int(rule110(1,0,0));
    write_char(10);
    write_int(rule110(1,0,1));
    write_char(10);
    write_int(rule110(1,1,0));
    write_char(10);
    write_int(rule110(1,1,1));
    write_char(10);
    return 0;
}
