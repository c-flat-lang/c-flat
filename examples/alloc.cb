use modules::mem;

type Pair struct {
    data: [2; s32],
}

fn exit(code: usize) void {
    syscall1(60, code);
}

pub fn main() void {
    // Reinterpret the raw mmap address as a typed pointer, then write/read it.
    let p = mem::alloc(64) as *Pair;
    p.data[0] = 13;
    p.data[1] = 29;
    let sum = p.data[0] + p.data[1]; // 42
    mem::free(p);
    exit(sum as usize);
}
