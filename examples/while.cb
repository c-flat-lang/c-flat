extern C fn write_int(s32) void;
extern C fn write_char(u8) void;

pub fn main() s32 {
    let mut array: [2; s32] = [ 0; 2 ];
    let mut i: s32 = 0;
    while i < array.len {
        let value = array[i];
        write_int(value);
        write_char(32);
        write_int(i);
        write_char(10);
        i = i + 1;
    }
    return i;
}
