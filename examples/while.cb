extern C fn write_s32(s32) void;
extern C fn write_char(u8) void;

pub fn main() s32 {
    let mut array: [2; s32] = [ 0; 2 ];
    let mut i: usize = 0;
    while i < array.len {
        let value = array[i];
        write_s32(value);
        write_char(32);
        write_s32(i);
        write_char(10);
        i = i + 1;
    }
    return i as s32;
}
