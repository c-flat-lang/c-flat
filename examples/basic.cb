use modules::math;
use modules::io::io_write_str;

pub fn main() s32 {
    let x = 123;
    let y: s32 = 205;
    io_write_str(&"min: ");
    let min_result: s32 = math::min<(s32)>(x, y);
    io_write_s32(min_result);
    io_write_str(&"\n");

    let max_result: s32 = math::max<(s32)>(x, y);
    io_write_str(&"max: ");
    io_write_s32(max_result);
    io_write_str(&"\n");

    return 0;
}
