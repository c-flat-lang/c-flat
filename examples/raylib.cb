fn main() s32 {
    let screenWidth = 1920;
    let screenHeight = 1080;

    initWindow(screenWidth, screenHeight);

    setTargetFPS(60);
    while windowShouldClose() {
        beginDrawing();

        clearBackground(0xFF_FF_FF_FF);

        endDrawing();
    }
    closeWindow();
    return 0;
}
