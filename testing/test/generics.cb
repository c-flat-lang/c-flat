extern C fn write_char(u8) void;
extern C fn write_s32(s32) void;

type Pair<(T: type)> struct {
    first: T,
    second: T,
}

fn make_pair<(T: type)>(a: T, b: T) Pair<(T)> {
    return Pair<(T)> {
        .first = a,
        .second = b,
    };
}

fn add<(T: type)>(x: T, y: T) T {
    return x + y;
}

pub fn main() s32 {
    let p: Pair<(s32)> = make_pair<(s32)>(10, 20);
    write_s32(p.first);
    write_char(10);
    write_s32(p.second);
    write_char(10);

    let num0 = add<(s32)>(123, 321);
    write_s32(num0);
    write_char(10);

    let num1 = add(100, 44);
    write_s32(num1);
    write_char(10);

    return 0;
}
