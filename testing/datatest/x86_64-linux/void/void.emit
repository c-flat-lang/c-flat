.intel_syntax noprefix
.globl main
  # Defining Function main
main:
  push rbp
  mov rbp, rsp
  sub rsp, 0
  # -- args --
main_entry:
exit_main:
  add rsp, 0
  mov rsp, rbp
  pop rbp
  ret
  # --- End of Function main ---