                     Tokenizer
Token { kind: Keyword(Pub), lexeme: "pub", span: 0..3 }
Token { kind: Keyword(Fn), lexeme: "fn", span: 4..6 }
Token { kind: Identifier, lexeme: "main", span: 7..11 }
Token { kind: LeftParen, lexeme: "(", span: 11..12 }
Token { kind: RightParen, lexeme: ")", span: 12..13 }
Token { kind: Identifier, lexeme: "s32", span: 14..17 }
Token { kind: LeftBrace, lexeme: "{", span: 18..19 }
Token { kind: Keyword(Return), lexeme: "return", span: 175..181 }
Token { kind: Number, lexeme: "0", span: 182..183 }
Token { kind: Semicolon, lexeme: ";", span: 183..184 }
Token { kind: RightBrace, lexeme: "}", span: 185..186 }